FROM python:3.12-slim

LABEL org.opencontainers.image.title="Airthingsprom" \
      org.opencontainers.image.description="Airthings air-quality Prometheus exporter" \
      org.opencontainers.image.source="https://github.com/petrovicboban/vueprom"

WORKDIR /app

COPY pyproject.toml README.md ./
COPY promexporters/ promexporters/
RUN pip install --no-cache-dir .

EXPOSE 8082

ENTRYPOINT ["promexporters", "--exporter", "airthings"]
CMD ["airthings.json"]
