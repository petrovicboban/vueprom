{
  "id": null,
  "uid": "vueprom-energy",
  "title": "Emporia Vue Energy Usage",
  "tags": ["vueprom", "energy"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "account",
        "label": "Account",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(energy_usage_watts, account)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {}
      },
      {
        "name": "device",
        "label": "Device",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(energy_usage_watts{account=~\"$account\"}, device)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Usage by Device (Watts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "energy_usage_watts{account=~\"$account\", device=~\"$device\", channel=\"Main\"}",
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Usage by Channel (Watts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "energy_usage_watts{account=~\"$account\", device=~\"$device\", channel!~\"Balance|TotalUsage|Main\"}",
          "legendFormat": "{{device}} – {{channel}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": { "lineWidth": 1 }
        }
      }
    },
    {
      "id": 3,
      "title": "Current Usage per Channel",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "energy_usage_watts{account=~\"$account\", device=~\"$device\", channel!~\"Balance|TotalUsage|Main\"}",
          "legendFormat": "{{device}} – {{channel}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      }
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ]
}
